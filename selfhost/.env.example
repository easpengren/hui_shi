# Copy this file to .env and fill values before running docker compose.

# Shared
APP_API_KEY=replace-with-long-random-key
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data
BASE_PUBLIC_URL=http://localhost:8080

# API limits
MAX_CHARS_PER_REQUEST=2800

# Worker
JOB_TIMEOUT_SECONDS=120
KOKORO_MODEL=kokoro
KOKORO_DEFAULT_VOICE=af_bella

# stub = generates deterministic WAV for contract testing.
# kokoro = reserved for real inference integration (not implemented in this starter).
SYNTH_BACKEND=stub
